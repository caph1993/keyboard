(defsrc
  esc  f1  f2   f3  f4   f5  f6   f7  f8   f9 f10  f11  f12 ins del
  grv   1    2    3    4    5    6    7    8    9    0    -    = bspc
  tab    q    w    e    r    t    y    u    i    o    p    [    ] \ 
  caps    a    s    d    f    g    h    j    k    l    ;    '    ret
  lsft     z    x    c    v    b    n    m    ,    .    /        rsft
  lctl   lmet lalt          spc             ralt rctl left up down right
)

;; (defalias
;;   s (t! type s)
;;   d (t! type d)
;; )
(defvar
  chord-timeout 50
)
(defchords chord-sd-tab $chord-timeout
  (s  ) (t! nomod s)
  (  d) (t! nomod d)
  (s d) tab
)
(defchords chord-kl-ret $chord-timeout
  (k  ) (t! nomod k)
  (  l) (t! nomod l)
  (k l) ret
)
(defchords chord-90-bspc $chord-timeout
  (9  ) (t! nomod 9)
  (  0) (t! nomod 0)
  (9 0) (fork bspc (macro S-9 S-0) (sft))
)
(defchords chord-23-esc $chord-timeout
  (2  ) (t! nomod 2)
  (  3) (t! nomod 3)
  (2 3) @esc
)

(deflayermap (base)
  ;; Row of F keys
  esc @esc

  ;; Row of numbers
  2    (chord chord-23-esc 2)
  3    (chord chord-23-esc 3)
  9    (chord chord-90-bspc 9)
  0    (chord chord-90-bspc 0)
  -    (t! rhrm   $tapping-term   -    rsft)

  ;; Row of qwe
  tab  (t!  hrm   $tapping-term   tab   @arrows-mouse)
  ;; q    (t! lhrm- $tot 350 q    lmet)
  w    (t! lhrm   $tapping-term   w    lalt)
  e    (t! lhrm   $tapping-term   e    lctl)
  r    (t! nomod r)
  t    (t! nomod t)
  y    (t! nomod y)
  u    (t! nomod u)
  i    (t! rhrm   $tapping-term   i    rctl)
  o    (t! rhrm   $tapping-term   o    lalt)
  p    (t! rhrm   $tapping-term   p    ralt)
  ;; p    (t! rhrm- $tot 350 p    lmet)
  [    (t! hrm    $tapping-term   [     (multi nop1 (layer-while-held disabled) (layer-while-held spc-arrows)))
  ]    (t! nomod ])

  ;; Row of asd
  caps (tap-hold 100 100 caps @num-FKeys)
  a    (t! nomod a)
  s    (chord chord-sd-tab s)
  d    (chord chord-sd-tab d)
  f    (t! lhrm   $tapping-term   f    lsft)
  g    (t! nomod g)
  h    (t! nomod h)
  j    (t! rhrm   $tapping-term   j    rsft)
  k    (chord chord-kl-ret k)
  l    (chord chord-kl-ret l)
  ;    (t! nomod ;)
  '    (t! rhrm   $tapping-term   '    @num-FKeys)
  
  ;; Row of z
  z    (t! nomod z)
  x    (t! nomod x)
  c    (t! lhrm   $tapping-term   c    ralt)
  v    (t! nomod v)
  b    (t! nomod b)
  n    (t! nomod n)
  m    (t! rhrm   $tapping-term   m    ralt)
  ,    (t! nomod ,)
  .    (t! nomod .)
  /    (t! nomod /)


  F1   (tap-hold 200 600 F1  @L1)
  F12  (tap-hold 200 600 F12 lrld)

  ;; spc  (tap-hold 200 200 spc nop2) ;; nop2=layer-lock

  ;; row of space
  spc (t! hrm      $tapping-term   spc @arrows-mouse)
  left @← up @↑ down @↓ right @→
)
(deflayermap spc-arrows
  spc (t! hrm      $tapping-term   spc @arrows-mouse)
)

(deflayermap nomods)

(defalias
  L0 (on-press press-vkey L0)
  L1 (on-press press-vkey L1)
  ;; unlock      (on-press press-vkey unlock)
  ;; lock-arrows (on-press press-vkey lock-arrows)
  ;; lock-mouse  (on-press press-vkey lock-mouse)
  ;; lock-num    (on-press press-vkey lock-num)
)
(defalias esc  (multi esc @L0)) ;; tap esc to exit custom layouts

(defvirtualkeys
  L1          (layer-while-held layout-IPA)
  L2          (layer-while-held layout-cyrillic)
  ;; lock-arrows (layer-while-held arrows-right)
  ;; lock-mouse  (layer-while-held mouse)
  ;; lock-num    (layer-while-held num)
)
(defvirtualkeys
  L0 (multi
    (on-press release-vkey L1)
    (on-press release-vkey L2)
  )
  ;; unlock (multi
  ;;   (on-press release-vkey lock-arrows)
  ;;   (on-press release-vkey lock-mouse)
  ;;   (on-press release-vkey lock-num)
  ;; )
)

(defalias
  arrows (multi
    (multi (layer-while-held arrows-left) (layer-while-held arrows-right))
  )
  mouse  (multi
    (layer-while-held mouse)
  )
  num  (multi
    (layer-while-held num)
  )
)

(defalias arrows-mouse (multi
  @arrows
  (fork XX @mouse (ralt))
))
(defalias num-FKeys (multi
  @num
  (fork XX (layer-while-held FKeys) (nop1)))
)


(defchords chord-arrows-i $chord-timeout
  (j) @←
  (i) @↑
  (k) @↓
  (o) @→
  (u) @bspc
  (l) @del
  ([) lctl

  (j i o) lrld

  ([ i) @☸↑
  ([ k) @☸↓
  ([ j) @C←
  ([ o) @C→
  ([ u) @Cbspc
  ([ l) @Cdel
  (k l) ret
  
)

(deflayermap arrows-left
  q (t! nomod \)
  w (t! lhrm  $tapping-term  - lalt)
  e (t! lhrm  $tapping-term  = lctl)
  r (t! nomod ')
  a (t! nomod ,)
  s (t! nomod .)
  d (t! nomod /) 
  f (t! lhrm  $tapping-term  ; lsft)
  g (t! nomod /)

  z C-z  x C-x  c C-c  v C-v
)

(deflayermap arrows-right
  y C-y
  u (chord chord-arrows-i u)
  i (chord chord-arrows-i i)
  o (chord chord-arrows-i o)
  j (chord chord-arrows-i j)
  k (chord chord-arrows-i k)
  l (chord chord-arrows-i l)

  1 S-1 2 S-2 3 S-3 4 S-4 5 S-5 6 S-6 7 S-7 8 S-8
  9 (fork (fork S-9 S-[ (nop1)) (fork (unmod (sft) [) , (nop1)) (sft))
  0 (fork (fork S-0 S-] (nop1)) (fork (unmod (sft) ]) . (nop1)) (sft))
  
  p XX
  h tab
  - (t!   hrm   $tapping-term  esc rsft)
  = esc
  ` esc
  [ (chord chord-arrows-i [)
  \ @*TeX
  n @btn1 m @btn2 , @*IPA
  spc (tap-hold 200 200 spc sft)
  ralt nop1
)

(deflayermap mouse
  j @🖱←   i @🖱↑  k @🖱↓   o @🖱→
  n 🖰1    m 🖰2
  x C-x   z C-z  c C-c    v C-v    y C-y
  u XX
  [ XX
  ] XX  
  lalt nop2 ;; slow movements
  rctl nop2 ;; slow movements
)

(deflayermap num
  q (t! lhrm    $tapping-term  1 lmet)
  w (t! lhrm    $tapping-term  2 lalt)
  e (t! lhrm    $tapping-term  3 lctl)
  f (t! lhrm    $tapping-term  4 lsft)
  g (t! nomod 5)
  h (t! nomod 6)
  j (t! rhrm    $tapping-term  7 rsft)
  i (t! rhrm    $tapping-term  8 rctl)
  o (t! rhrm    $tapping-term  9 lalt)
  p (t! rhrm    $tapping-term  0 ralt)
  m '  k [  l ]  ; \
  a \  s `  d -  v =
)
(deflayermap FKeys
  q (t! lhrm    $tapping-term  (fork F1  @fn-F1  (nop1)) lmet)
  w (t! lhrm    $tapping-term  (fork F2  @fn-F2  (nop1)) lalt)
  e (t! lhrm    $tapping-term  (fork F3  @fn-F3  (nop1)) lctl)
  f (t! lhrm    $tapping-term  (fork F4  @fn-F4  (nop1)) lsft)
  g (t! nomod         (fork F5  @fn-F5  (nop1)))
  h (t! nomod         (fork F6  @fn-F6  (nop1)))
  j (t! rhrm    $tapping-term  (fork F7  @fn-F7  (nop1)) rsft)
  i (t! rhrm    $tapping-term  (fork F8  @fn-F8  (nop1)) rctl)
  o (t! rhrm    $tapping-term  (fork F9  @fn-F9  (nop1)) lalt)
  p (t! rhrm    $tapping-term  (fork F10 @fn-F10 (nop1)) ralt)
  r (t! nomod         (fork F11 @fn-F11 (nop1)))
  u (t! nomod         (fork F12 @fn-F12 (nop1)))
  t PrintScreen
  y PrintScreen
  ralt (multi nop1 (layer-while-held FKeys)) ;; fn keys
  spc (tap-hold 200 200 spc (layer-while-held FKeys))
)
(defalias
  ;; names: https://github.com/jtroo/kanata/blob/main/parser/src/keys/mod.rs
  fn-F1 mute
  fn-F2 VolumeDown
  fn-F3 VolumeUp
  fn-F4 blup
  fn-F5 bldn
  fn-F6 brup
  fn-F7 brdown
  fn-F8 XX
  fn-F9 XX
  fn-F10 PrintScreen
  fn-F11 home
  fn-F12 end
)



;; Reference layers for copy-paste
(deflayer empty
  _    _   _    _   _    _   _    _   _    _  _    _    _   _   _  
  _     _    _    _    _    _    _    _    _    _    _    _    _ _   
  _      _    _    _    _    _    _    _    _    _    _    _    _ _ 
  _       _    _    _    _    _    _    _    _    _    _    _    _  
  _        _    _    _    _    _    _    _    _    _    _        _   
  _      _    _             _               _    _    _    _  _    _    
)
(deflayer disabled
  XX   XX  XX   XX  XX   XX  XX   XX  XX   XX XX   XX   XX  XX  XX 
  XX    XX   XX   XX   XX   XX   XX   XX   XX   XX   XX   XX   XX XX  
  XX     XX   XX   XX   XX   XX   XX   XX   XX   XX   XX   XX   XX XX 
  XX      XX   XX   XX   XX   XX   XX   XX   XX   XX   XX   XX   XX 
  XX       XX   XX   XX   XX   XX   XX   XX   XX   XX   XX       XX  
  XX     XX   XX            XX              XX   XX   XX   XX XX   XX   
)
(defalias disabled (multi
  (layer-while-held empty)
))
;; Tip. Use: (multi (layer-while-held disabled) (layer-while-held some-layer)) to block all keys but those defined in some-layer


(include "configs/sldr.kbd")
(defalias *TeX (multi @*sldr (macro (unicode *) 150 bspc sldr 5 \)))
(defalias *IPA (multi @*sldr (macro (unicode *) 150 bspc sldr 5 S-`)))


;; ----------------------------------------------------------
;; Tab and arrows layer
;; ----------------------------------------------------------

(include "configs/mouse.kbd")

;; nop0 is the "go to extreme" button <=>l
;; nop3 is a "ctl" button. All ctl buttons trigger nop3, except the tab key for which certain keys are unmoded.
;; Repeated arrow means ctrl+arrow (word jump). Only defined for left and right.
(defalias ↑    (fork up   @☸↑ (nop1)))
(defalias ↓    (fork down @☸↓ (nop1)))
(defalias ←    (fork left home (nop1)))
(defalias →    (fork right end (nop1)))
(defalias C←   (fork (tap-hold 200 300 C-left (macro home)) home (nop1)))
(defalias C→   (fork (tap-hold 200 300 C-right (macro end)) end (nop1)))
(defalias btn1 (fork ret   🖰1   (nop1)))
(defalias btn2 (fork @*TeX 🖰2   (nop1)))
(defalias btn3 (fork ContextMenu   🖰3   (nop1)))
(defalias bspc  (tap-hold 200 600 bspc   (macro (unmod lsft home) (unmod bspc))))
(defalias Cbspc (tap-hold 200 600 C-bspc (macro (unmod lsft home) (unmod bspc))))
(defalias del   (tap-hold 200 600 del    (macro (unmod lsft end ) (unmod del ))))
(defalias Cdel  (tap-hold 200 600 C-del  (macro (unmod lsft end ) (unmod del ))))

;; Either there is a bug of a hardware issue when pressing multiple keys (holding three and pressing the fourh): (` = ralt o) works and (` = ralt j) works, but (` = ralt i) and (` = ralt j) don't. The software doesn't detect it at all.

;; ----------------------------------------------------------
;; Custom layouts and sldr commands (mostly TeX)
;; ----------------------------------------------------------
